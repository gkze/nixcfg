+_nix_add_flake_input_gcroots() {
+  local flake_inputs=${1%/}
+  local flake_input_paths=$2
+  local root_name=${3:-input}
+  local store_path
+  local -a store_paths=()
+  local -A seen_store_paths=()
+
+  while [[ $flake_input_paths =~ /nix/store/[^\"]+ ]]; do
+    store_path="${BASH_REMATCH[0]}"
+    flake_input_paths="${flake_input_paths/${store_path}/}"
+
+    if [[ -n ${seen_store_paths[$store_path]+x} ]]; then
+      continue
+    fi
+
+    seen_store_paths["$store_path"]=1
+    store_paths+=("$store_path")
+  done
+
+  # Do not let an empty input list make `nix build` default to the current flake.
+  if ((${#store_paths[@]} == 0)); then
+    return 0
+  fi
+
+  _nix build --out-link "${flake_inputs}/${root_name}" "${store_paths[@]}"
+}
+
+_nix_clean_stale_flake_gcroots() {
+  local layout_dir=$1
+  local current_profile=$2
+  local current_profile_rc=$3
+  local current_flake_input_root=$4
+  local gcroot
+
+  for gcroot in "$layout_dir"/{nix,flake}-profile*; do
+    if [[ $gcroot != "$current_profile" && $gcroot != "$current_profile_rc" ]]; then
+      rm -f "$gcroot"
+    fi
+  done
+
+  for gcroot in "$layout_dir/flake-inputs/"*; do
+    if [[ $gcroot != "$current_flake_input_root" && $gcroot != "$current_flake_input_root"-* ]]; then
+      rm -f "$gcroot"
+    fi
+  done
+}
