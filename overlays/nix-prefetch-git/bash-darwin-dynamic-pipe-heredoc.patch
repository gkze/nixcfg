+	 We set the pipe's write end to be non-blocking, try to write, and
+	 fall back to a temp file on error. */
+      if (sh_setnodelay (herepipe[1]) < 0)
+	{
+	  close (herepipe[0]);
+	  close (herepipe[1]);
+	  goto use_tempfile;
+	}
+#endif
