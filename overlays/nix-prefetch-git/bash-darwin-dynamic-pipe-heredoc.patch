Backport the dynamic-pipe heredoc fix from GNU Bash devel commit
03e7298d1eb7f7163cda94ee23dcfa983152a540.

macOS can throttle newly-created pipe capacity from 64 KiB to 512 bytes after
the system-wide pipe KVA high-water mark is reached. Make the heredoc pipe's
write end nonblocking and fall back to a temporary file when the capacity seen
at runtime is smaller than the capacity detected while building Bash.

--- configure
+++ configure
@@ -23136,7 +23136,7 @@
 dgux*)	LOCAL_CFLAGS=-D_DGUX_SOURCE; LOCAL_LIBS=-ldgc ;;
 isc*)	LOCAL_CFLAGS=-Disc386 ;;
 rhapsody*)	LOCAL_CFLAGS=-DRHAPSODY ;;
-darwin*)	LOCAL_CFLAGS=-DMACOSX ;;
+darwin*)	LOCAL_CFLAGS="-DMACOSX -DPIPESIZE_DYNAMIC" ;;
 sco3.2v5*)	LOCAL_CFLAGS="-b elf -DWAITPID_BROKEN -DPATH_MAX=1024" ;;
 sco3.2v4*)	LOCAL_CFLAGS="-DMUST_UNBLOCK_CHLD -DPATH_MAX=1024" ;;
 sco3.2*)	LOCAL_CFLAGS=-DMUST_UNBLOCK_CHLD ;;
