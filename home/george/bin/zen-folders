#!/usr/bin/env -S uv run --script
# vi: set ft=python :
# /// script
# requires-python = ">=3.12"
# dependencies = [
#   "lz4>=4.4.4",
#   "pyyaml>=6.0.2",
# ]
# ///
"""Declarative pinned-tab folder management for Zen browser.

Zen stores session data in a Mozilla LZ4-compressed JSON file. Folders require
entries in BOTH the `groups` array (Firefox creates native tab-group DOM nodes)
and the `folders` array (Zen upgrades them into zen-folder elements). Tabs are
assigned to folders via their `groupId` field. Each folder also needs a hidden
empty placeholder tab linked by `emptyTabIds`.

This tool reconciles the session against a declarative YAML config file.
List order in YAML = render order. Workspace is referenced by human name.
Tabs are matched by URL substring (case-insensitive).

Optional workspace metadata lives under `__workspace__`, for example:

    Work:
      __workspace__:
        icon: "🏢"
        containerTabId: 6
        hasCollapsedPinnedTabs: false
        theme:
          gradientColors: ["#8caaee", "#99d1db"]
          opacity: 0.5
          texture: 0
      AI:
        OpenAI: platform.openai.com

`containerTabId` is used when creating a missing workspace. Existing
workspaces keep their current container ID; zen-folders warns instead of
rewriting it in-place.

Zen must be closed when making changes -- it overwrites the session on quit.
"""

from __future__ import annotations

import argparse
import configparser
import contextlib
import errno
import json
import os
import shutil
import subprocess
import sys
import time
import uuid as uuidlib
from contextlib import suppress
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Final, cast

import lz4.block
import yaml
from yaml.constructor import ConstructorError
from yaml.resolver import BaseResolver

fcntl: Any = None
with suppress(ImportError):  # pragma: no cover - non-POSIX fallback
    fcntl = __import__("fcntl")

ZEN_APPLICATION_SUPPORT: Final = Path.home() / "Library/Application Support/zen"
ZEN_PROFILES: Final = ZEN_APPLICATION_SUPPORT / "Profiles"
PROFILES_INI: Final = ZEN_APPLICATION_SUPPORT / "profiles.ini"
SESSION_FILENAME: Final = "zen-sessions.jsonlz4"
SESSION_HEADER_PREFIX: Final[bytes] = b"mozLz40\0"
SESSION_HEADER_SIZE: Final[int] = 12
DEFAULT_YAML: Final = Path.home() / ".config/zen/folders.yaml"
GROUP_COLOR: Final = "zen-workspace-color"
WORKSPACE_META_KEY: Final = "__workspace__"
DEFAULT_WORKSPACE_THEME: Final = {
    "type": "gradient",
    "gradientColors": [],
    "opacity": 0.5,
    "texture": 0,
}
MAX_SESSION_UNCOMPRESSED_BYTES: Final = 256 * 1024 * 1024
MAX_ID_ATTEMPTS: Final = 10000
PROFILE_LOCK_FILENAMES: Final[tuple[str, ...]] = ("parent.lock", ".parentlock", "lock")


class ZenFoldersError(RuntimeError):
    """User-facing command error."""


class SessionFormatError(ZenFoldersError):
    """Session file exists but does not match expected structure."""


class UniqueKeyLoader(yaml.SafeLoader):
    """YAML loader that rejects duplicate mapping keys."""


@dataclass(frozen=True)
class WorkspaceThemeSpec:
    """Declarative workspace theme metadata parsed from config."""

    type: str = "gradient"
    gradient_colors: tuple[str, ...] = ()
    opacity: float = 0.5
    texture: int = 0

    def to_session_dict(self) -> dict[str, object]:
        """Convert to the theme shape stored in Zen session JSON."""
        return {
            "type": self.type,
            "gradientColors": list(self.gradient_colors),
            "opacity": self.opacity,
            "texture": self.texture,
        }

    def to_config_dict(self) -> dict[str, object]:
        """Convert to the declarative YAML shape used by zen-folders."""
        data: dict[str, object] = {
            "gradientColors": list(self.gradient_colors),
            "opacity": self.opacity,
            "texture": self.texture,
        }
        if self.type != DEFAULT_WORKSPACE_THEME["type"]:
            data["type"] = self.type
        return data

    def is_default(self) -> bool:
        """Return whether this matches Zen's current workspace theme default."""
        return self == WorkspaceThemeSpec()


@dataclass(frozen=True)
class WorkspaceSpec:
    """Declarative workspace metadata parsed from config."""

    name: str
    icon: str | None = None
    container_tab_id: int | None = None
    has_collapsed_pinned_tabs: bool | None = None
    theme: WorkspaceThemeSpec | None = None


@dataclass(frozen=True)
class ZenRuntimeState:
    """Best-effort runtime detection result for one profile."""

    running: bool
    warnings: tuple[str, ...] = ()


def _stdout(message: str = "") -> None:
    sys.stdout.write(f"{message}\n")


def _stderr(message: str = "") -> None:
    sys.stderr.write(f"{message}\n")


def _stdout_raw(message: str) -> None:
    sys.stdout.write(message)


def _construct_mapping_no_dupes(
    loader: UniqueKeyLoader,
    node: yaml.nodes.MappingNode,
) -> dict:
    """Construct a mapping while rejecting duplicate keys."""
    mapping: dict = {}
    for key_node, value_node in node.value:
        key = loader.construct_object(key_node)
        if key in mapping:
            msg = "while constructing a mapping"
            raise ConstructorError(
                msg,
                node.start_mark,
                f"found duplicate key {key!r}",
                key_node.start_mark,
            )
        mapping[key] = loader.construct_object(value_node)
    return mapping


def _load_yaml_with_unique_keys(text: str) -> object:
    """Load YAML with duplicate-key rejection enabled."""
    loader = UniqueKeyLoader(text)
    try:
        return loader.get_single_data()
    finally:
        loader.dispose()


UniqueKeyLoader.add_constructor(
    BaseResolver.DEFAULT_MAPPING_TAG,
    _construct_mapping_no_dupes,
)


# -- Session I/O -------------------------------------------------------------


def _load_profiles_ini() -> configparser.RawConfigParser | None:
    """Load Zen's profiles.ini if it exists and is parseable."""
    if not PROFILES_INI.exists():
        return None

    parser = configparser.RawConfigParser()
    try:
        with PROFILES_INI.open(encoding="utf-8") as handle:
            parser.read_file(handle)
    except (OSError, configparser.Error):
        return None
    return parser


def _profile_path_from_ini(raw_path: str) -> Path | None:
    """Resolve one profiles.ini path field into an absolute profile path."""
    value = raw_path.strip()
    if not value:
        return None
    path = Path(value).expanduser()
    if not path.is_absolute():
        path = ZEN_APPLICATION_SUPPORT / path
    return path


def _profiles_from_ini() -> list[tuple[str, Path, bool]]:
    """Return (name, path, is_default) tuples from profiles.ini."""
    parser = _load_profiles_ini()
    if parser is None:
        return []

    profiles: list[tuple[str, Path, bool]] = []
    for section in parser.sections():
        if not section.startswith("Profile"):
            continue
        name = parser.get(section, "Name", fallback="").strip()
        path = _profile_path_from_ini(parser.get(section, "Path", fallback=""))
        if path is None:
            continue
        profiles.append((
            name,
            path,
            parser.getboolean(section, "Default", fallback=False),
        ))
    return profiles


def _profile_dir_from_name(name: str) -> Path | None:
    """Resolve a human profile name from profiles.ini to a directory."""
    name_cf = name.strip().casefold()
    if not name_cf:
        return None

    for profile_name, path, _ in _profiles_from_ini():
        if profile_name and profile_name.casefold() == name_cf:
            return path
    return None


def _default_profile_dir() -> Path | None:
    """Auto-detect the default Zen profile directory."""
    parser = _load_profiles_ini()
    if parser is not None:
        for section in parser.sections():
            if not section.startswith("Install"):
                continue
            path = _profile_path_from_ini(parser.get(section, "Default", fallback=""))
            if path is not None:
                return path

    for _, path, is_default in _profiles_from_ini():
        if is_default:
            return path

    profiles = _profiles_from_ini()
    if profiles:
        return profiles[0][1]

    if ZEN_PROFILES.exists():
        dirs = sorted(path for path in ZEN_PROFILES.iterdir() if path.is_dir())
        if len(dirs) == 1:
            return dirs[0]

    return None


def _available_profile_hints() -> str:
    """Return profile names or directory names for error messages."""
    names = [name for name, _, _ in _profiles_from_ini() if name]
    if names:
        return ", ".join(names)

    if ZEN_PROFILES.exists():
        dirs = sorted(path.name for path in ZEN_PROFILES.iterdir() if path.is_dir())
        if dirs:
            return ", ".join(dirs)

    return "<none found>"


def resolve_profile_dir(profile: str | None) -> Path:
    """Resolve a profile selector into an on-disk profile directory path."""
    if profile is None or not profile.strip():
        detected = _default_profile_dir()
        if detected is not None:
            return detected
        msg = (
            "Unable to auto-detect a Zen profile. Pass --profile with a "
            "profile name, directory, or session file path."
        )
        raise ZenFoldersError(msg)

    candidate = Path(profile).expanduser()
    if candidate.is_file():
        return candidate.parent
    if candidate.exists():
        if candidate.is_dir():
            return candidate
        msg = f"Profile path is not a directory: {candidate}"
        raise ZenFoldersError(msg)
    if candidate.is_absolute():
        msg = f"Profile not found: {candidate}"
        raise ZenFoldersError(msg)

    profile_path = ZEN_PROFILES / profile
    if profile_path.exists():
        if profile_path.is_dir():
            return profile_path
        msg = f"Profile path is not a directory: {profile_path}"
        raise ZenFoldersError(msg)

    named_profile = _profile_dir_from_name(profile)
    if named_profile is not None:
        return named_profile

    msg = f"Profile '{profile}' not found. Available: {_available_profile_hints()}"
    raise ZenFoldersError(msg)


def session_file(profile: str | None) -> Path:
    """Resolve a profile argument to an on-disk session file path."""
    if profile is not None:
        candidate = Path(profile).expanduser()
        if candidate.is_file():
            return candidate

    profile_path = resolve_profile_dir(profile)
    path = profile_path / SESSION_FILENAME
    if not path.exists():
        msg = f"Session file not found: {path}"
        raise ZenFoldersError(msg)
    if not path.is_file():
        msg = f"Session path is not a file: {path}"
        raise ZenFoldersError(msg)

    return path


def ensure_session_shape(session: dict) -> None:
    """Ensure expected top-level session arrays exist and are list-typed."""
    for key in ("tabs", "groups", "folders", "spaces"):
        value = session.get(key)
        if value is None:
            session[key] = []
            continue
        if not isinstance(value, list):
            msg = f"Session field '{key}' must be a list."
            raise SessionFormatError(msg)


def read_session(path: Path) -> dict:
    """Read and validate a Mozilla LZ4 session file."""
    try:
        data = path.read_bytes()
    except OSError as exc:
        msg = f"Unable to read session file: {path}: {exc}"
        raise ZenFoldersError(msg) from exc

    if len(data) < SESSION_HEADER_SIZE:
        msg = f"Session file is too small: {path}"
        raise SessionFormatError(msg)
    if data[: len(SESSION_HEADER_PREFIX)] != SESSION_HEADER_PREFIX:
        msg = f"Not a Mozilla LZ4 file: {path}"
        raise SessionFormatError(msg)

    size = int.from_bytes(
        data[len(SESSION_HEADER_PREFIX) : SESSION_HEADER_SIZE], "little"
    )
    if size <= 0:
        msg = f"Invalid uncompressed size in session header: {size}"
        raise SessionFormatError(msg)
    if size > MAX_SESSION_UNCOMPRESSED_BYTES:
        msg = f"Session payload too large ({size} bytes > {MAX_SESSION_UNCOMPRESSED_BYTES} bytes)."
        raise SessionFormatError(
            msg,
        )

    try:
        raw = lz4.block.decompress(data[SESSION_HEADER_SIZE:], uncompressed_size=size)
        decoded = json.loads(raw)
    except (ValueError, lz4.block.LZ4BlockError, json.JSONDecodeError) as exc:
        msg = f"Failed to parse session file: {path}: {exc}"
        raise SessionFormatError(msg) from exc

    if not isinstance(decoded, dict):
        msg = f"Session root must be a JSON object: {path}"
        raise SessionFormatError(msg)

    ensure_session_shape(decoded)
    return decoded


def write_session(path: Path, obj: dict) -> None:
    """Write a validated session object back to Mozilla LZ4 format."""
    ensure_session_shape(obj)
    raw = json.dumps(obj, separators=(",", ":")).encode()
    compressed = lz4.block.compress(raw, store_size=False)
    mode: int | None = None
    try:
        mode = path.stat().st_mode & 0o777
    except OSError:
        mode = None
    temp_path = path.with_name(
        f".{path.name}.tmp-{os.getpid()}-{int(time.time_ns() % 1_000_000_000)}",
    )

    try:
        with temp_path.open("wb") as handle:
            handle.write(SESSION_HEADER_PREFIX)
            handle.write(len(raw).to_bytes(4, "little"))
            handle.write(compressed)
            handle.flush()
            os.fsync(handle.fileno())
        if mode is not None:
            Path(temp_path).chmod(mode)
        Path(temp_path).replace(path)
        # Best-effort durability for the directory entry after atomic replace.
        try:
            dir_fd = os.open(path.parent, os.O_RDONLY)
        except OSError:
            dir_fd = None
        if dir_fd is not None:
            try:
                os.fsync(dir_fd)
            except OSError:
                pass
            finally:
                os.close(dir_fd)
    except OSError as exc:
        msg = f"Unable to write session file: {path}: {exc}"
        raise ZenFoldersError(msg) from exc
    finally:
        if temp_path.exists():
            temp_path.unlink(missing_ok=True)


# -- YAML I/O ----------------------------------------------------------------


def load_yaml(path: Path) -> dict:
    """Load YAML config and validate a mapping root."""
    if not path.exists():
        msg = f"Config file not found: {path}"
        raise ZenFoldersError(msg)
    try:
        text = path.read_text(encoding="utf-8")
    except OSError as exc:
        msg = f"Unable to read config file: {path}: {exc}"
        raise ZenFoldersError(msg) from exc

    try:
        data = _load_yaml_with_unique_keys(text)
    except yaml.YAMLError as exc:
        msg = f"Invalid YAML in {path}: {exc}"
        raise ZenFoldersError(msg) from exc

    if not isinstance(data, dict):
        msg = f"Config root must be a YAML mapping: {path}"
        raise ZenFoldersError(msg)
    return data


def _parse_workspace_key(raw: dict) -> str:
    """Extract and validate the single workspace key from raw config."""
    if not raw:
        msg = "Config file is empty."
        raise ZenFoldersError(msg)
    if len(raw) != 1:
        keys = ", ".join(str(key) for key in raw)
        msg = (
            "Config must have exactly one top-level key (workspace name), "
            f"got {len(raw)}: {keys}"
        )
        raise ZenFoldersError(msg)

    workspace_key = next(iter(raw))
    if not isinstance(workspace_key, str) or not workspace_key.strip():
        msg = "Workspace name (top-level key) must be a non-empty string."
        raise ZenFoldersError(msg)
    return workspace_key


def _normalize_tab_specs(folder_name: str, tabs_raw: object) -> list[dict]:
    """Normalize one folder's tab mapping into ordered tab spec objects."""
    if tabs_raw is None:
        return []
    if not isinstance(tabs_raw, dict):
        msg = (
            f"Folder '{folder_name}' must map to a tab mapping, "
            f"not {type(tabs_raw).__name__}."
        )
        raise ZenFoldersError(msg)

    tabs: list[dict] = []
    for title, url in tabs_raw.items():
        if not isinstance(title, str) or not title.strip():
            msg = f"Tab titles in folder '{folder_name}' must be non-empty strings."
            raise ZenFoldersError(msg)
        if not isinstance(url, str) or not url.strip():
            msg = (
                f"Tab '{title}' in folder '{folder_name}' "
                "must have a non-empty URL pattern."
            )
            raise ZenFoldersError(msg)
        tabs.append({"title": title.strip(), "url": url.strip()})
    return tabs


def _parse_workspace_theme(workspace: str, raw_theme: object) -> WorkspaceThemeSpec:
    """Validate and normalize one declarative workspace theme block."""
    if not isinstance(raw_theme, dict):
        msg = (
            f"Workspace '{workspace}' theme must be an object, "
            f"not {type(raw_theme).__name__}."
        )
        raise ZenFoldersError(msg)

    theme_map = cast("dict[str, object]", raw_theme)
    allowed_keys = {"type", "gradientColors", "opacity", "texture"}
    unknown_keys = sorted(key for key in theme_map if key not in allowed_keys)
    if unknown_keys:
        msg = (
            f"Unsupported theme key(s) in workspace '{workspace}': "
            f"{', '.join(unknown_keys)}"
        )
        raise ZenFoldersError(msg)

    default_theme_type = cast("str", DEFAULT_WORKSPACE_THEME["type"])
    theme_type_obj = theme_map.get("type", default_theme_type)
    if not isinstance(theme_type_obj, str) or not theme_type_obj.strip():
        msg = f"Workspace '{workspace}' theme.type must be a non-empty string."
        raise ZenFoldersError(msg)
    theme_type = theme_type_obj.strip()
    if theme_type != "gradient":
        msg = (
            f"Workspace '{workspace}' theme.type must currently be 'gradient', "
            f"not {theme_type!r}."
        )
        raise ZenFoldersError(msg)

    raw_colors_obj = theme_map.get("gradientColors", [])
    if not isinstance(raw_colors_obj, list):
        msg = (
            f"Workspace '{workspace}' theme.gradientColors must be a list, "
            f"not {type(raw_colors_obj).__name__}."
        )
        raise ZenFoldersError(msg)
    gradient_colors: list[str] = []
    for color in raw_colors_obj:
        if not isinstance(color, str) or not color.strip():
            msg = (
                f"Workspace '{workspace}' theme.gradientColors entries must be "
                "non-empty strings."
            )
            raise ZenFoldersError(msg)
        gradient_colors.append(color.strip())

    default_opacity = cast("float", DEFAULT_WORKSPACE_THEME["opacity"])
    opacity_obj = theme_map.get("opacity", default_opacity)
    if not isinstance(opacity_obj, int | float) or isinstance(opacity_obj, bool):
        msg = (
            f"Workspace '{workspace}' theme.opacity must be a number, "
            f"not {type(opacity_obj).__name__}."
        )
        raise ZenFoldersError(msg)
    opacity = float(opacity_obj)
    if opacity < 0 or opacity > 1:
        msg = f"Workspace '{workspace}' theme.opacity must be between 0 and 1."
        raise ZenFoldersError(msg)

    default_texture = cast("int", DEFAULT_WORKSPACE_THEME["texture"])
    texture_obj = theme_map.get("texture", default_texture)
    if not isinstance(texture_obj, int) or isinstance(texture_obj, bool):
        msg = (
            f"Workspace '{workspace}' theme.texture must be an integer, "
            f"not {type(texture_obj).__name__}."
        )
        raise ZenFoldersError(msg)
    if texture_obj < 0:
        msg = f"Workspace '{workspace}' theme.texture must be >= 0."
        raise ZenFoldersError(msg)

    return WorkspaceThemeSpec(
        type=theme_type,
        gradient_colors=tuple(gradient_colors),
        opacity=opacity,
        texture=texture_obj,
    )


def _parse_workspace_spec(workspace: str, folders_raw: object) -> WorkspaceSpec:
    """Parse optional workspace metadata from one workspace mapping."""
    if folders_raw is None:
        return WorkspaceSpec(name=workspace)
    if not isinstance(folders_raw, dict):
        msg = (
            f"Workspace '{workspace}' must map to a folder mapping, "
            f"not {type(folders_raw).__name__}."
        )
        raise ZenFoldersError(msg)

    folders_map = cast("dict[str, object]", folders_raw)
    raw_meta = folders_map.get(WORKSPACE_META_KEY)
    if raw_meta is None:
        return WorkspaceSpec(name=workspace)
    if not isinstance(raw_meta, dict):
        msg = (
            f"Workspace metadata key {WORKSPACE_META_KEY!r} in '{workspace}' "
            f"must map to an object, not {type(raw_meta).__name__}."
        )
        raise ZenFoldersError(msg)

    meta_map = cast("dict[str, object]", raw_meta)
    allowed_keys = {"icon", "containerTabId", "hasCollapsedPinnedTabs", "theme"}
    unknown_keys = sorted(key for key in meta_map if key not in allowed_keys)
    if unknown_keys:
        msg = (
            f"Unsupported workspace metadata key(s) in '{workspace}': "
            f"{', '.join(unknown_keys)}"
        )
        raise ZenFoldersError(msg)

    icon = meta_map.get("icon")
    if icon is not None:
        if not isinstance(icon, str) or not icon.strip():
            msg = f"Workspace '{workspace}' icon must be a non-empty string."
            raise ZenFoldersError(msg)
        icon = icon.strip()

    raw_container_tab_id = meta_map.get("containerTabId")
    container_tab_id: int | None = None
    if raw_container_tab_id is not None:
        if not isinstance(raw_container_tab_id, int) or isinstance(
            raw_container_tab_id, bool
        ):
            msg = (
                f"Workspace '{workspace}' containerTabId must be an integer, "
                f"not {type(raw_container_tab_id).__name__}."
            )
            raise ZenFoldersError(msg)
        if raw_container_tab_id < 0:
            msg = f"Workspace '{workspace}' containerTabId must be >= 0."
            raise ZenFoldersError(msg)
        container_tab_id = raw_container_tab_id

    raw_collapsed = meta_map.get("hasCollapsedPinnedTabs")
    has_collapsed_pinned_tabs: bool | None = None
    if raw_collapsed is not None:
        if not isinstance(raw_collapsed, bool):
            msg = (
                f"Workspace '{workspace}' hasCollapsedPinnedTabs must be a bool, "
                f"not {type(raw_collapsed).__name__}."
            )
            raise ZenFoldersError(msg)
        has_collapsed_pinned_tabs = raw_collapsed

    raw_theme = meta_map.get("theme")
    theme = (
        _parse_workspace_theme(workspace, raw_theme) if raw_theme is not None else None
    )

    return WorkspaceSpec(
        name=workspace,
        icon=icon,
        container_tab_id=container_tab_id,
        has_collapsed_pinned_tabs=has_collapsed_pinned_tabs,
        theme=theme,
    )


def _normalize_folder_specs(workspace: str, folders_raw: object) -> list[dict]:
    """Normalize folder definitions for one workspace."""
    if folders_raw is None:
        return []
    if not isinstance(folders_raw, dict):
        msg = (
            f"Workspace '{workspace}' must map to a folder mapping, "
            f"not {type(folders_raw).__name__}."
        )
        raise ZenFoldersError(msg)

    folders: list[dict] = []
    seen_names: set[str] = set()
    for folder_name, tabs_raw in folders_raw.items():
        if folder_name == WORKSPACE_META_KEY:
            continue
        if not isinstance(folder_name, str) or not folder_name.strip():
            msg = "Folder names must be non-empty strings."
            raise ZenFoldersError(msg)
        normalized_name = folder_name.strip()
        name_cf = normalized_name.casefold()
        if name_cf in seen_names:
            msg = f"Duplicate folder name '{normalized_name}' in config."
            raise ZenFoldersError(msg)
        seen_names.add(name_cf)

        tabs = _normalize_tab_specs(normalized_name, tabs_raw)
        folders.append({"name": normalized_name, "tabs": tabs})

    return folders


def parse_config(raw: dict) -> tuple[WorkspaceSpec, list[dict]]:
    """Parse YAML config into workspace metadata plus normalized folders."""
    workspace_key = _parse_workspace_key(raw)
    workspace = workspace_key.strip()
    workspace_raw = raw[workspace_key]
    return (
        _parse_workspace_spec(workspace, workspace_raw),
        _normalize_folder_specs(workspace, workspace_raw),
    )


# -- Helpers ------------------------------------------------------------------


def load_session(profile: str | None) -> tuple[Path, dict]:
    """Load and decode a profile's session payload."""
    path = session_file(profile)
    return path, read_session(path)


def _tab_entry_field(tab: dict, field: str) -> str:
    """Extract a field from the tab's current navigation entry."""
    entries = tab.get("entries", [])
    if not isinstance(entries, list) or not entries:
        return ""
    raw_index = tab.get("index")
    idx = (raw_index - 1) if isinstance(raw_index, int) else (len(entries) - 1)
    idx = max(0, min(idx, len(entries) - 1))
    entry = entries[idx]
    if not isinstance(entry, dict):
        return ""
    value = entry.get(field, "")
    return value if isinstance(value, str) else ""


def tab_url(tab: dict) -> str:
    """Return the active URL for a tab entry."""
    return _tab_entry_field(tab, "url")


def tab_title(tab: dict) -> str:
    """Return the active title for a tab entry."""
    return _tab_entry_field(tab, "title")


def workspace_record_by_name(session: dict, name: str) -> dict | None:
    """Return the workspace record matching *name*, if present."""
    name_cf = name.strip().casefold()
    for space in session.get("spaces", []):
        if not isinstance(space, dict):
            continue
        space_name = space.get("name")
        if isinstance(space_name, str) and space_name.casefold() == name_cf:
            return space
    return None


def workspace_record_by_uuid(session: dict, uuid: str) -> dict | None:
    """Return the workspace record matching *uuid*, if present."""
    for space in session.get("spaces", []):
        if isinstance(space, dict) and space.get("uuid") == uuid:
            return space
    return None


def workspace_container_tab_id(session: dict, workspace_uuid: str) -> int:
    """Return the numeric container tab ID for one workspace."""
    space = workspace_record_by_uuid(session, workspace_uuid)
    if not isinstance(space, dict):
        return 0
    raw = space.get("containerTabId", 0)
    if isinstance(raw, dict):
        raw = raw.get("id", 0)
    if isinstance(raw, int) and not isinstance(raw, bool) and raw >= 0:
        return raw
    return 0


def workspace_has_collapsed_pinned_tabs(space: dict) -> bool:
    """Return the persisted collapsed-pinned-tabs flag for one workspace."""
    return bool(space.get("hasCollapsedPinnedTabs", False))


def workspace_theme_from_record(space: dict) -> WorkspaceThemeSpec:
    """Normalize one session workspace theme into the declarative theme shape."""
    raw_theme = space.get("theme")
    if not isinstance(raw_theme, dict):
        return WorkspaceThemeSpec()

    theme_map = cast("dict[str, object]", raw_theme)
    default_theme_type = cast("str", DEFAULT_WORKSPACE_THEME["type"])
    theme_type_obj = theme_map.get("type", default_theme_type)
    if not isinstance(theme_type_obj, str) or not theme_type_obj.strip():
        theme_type_obj = default_theme_type

    raw_colors_obj = theme_map.get("gradientColors", [])
    if not isinstance(raw_colors_obj, list):
        raw_colors_obj = []
    gradient_colors = tuple(
        color.strip()
        for color in raw_colors_obj
        if isinstance(color, str) and color.strip()
    )

    default_opacity = cast("float", DEFAULT_WORKSPACE_THEME["opacity"])
    opacity_obj = theme_map.get("opacity", default_opacity)
    if (
        not isinstance(opacity_obj, int | float)
        or isinstance(opacity_obj, bool)
        or opacity_obj < 0
        or opacity_obj > 1
    ):
        opacity_obj = default_opacity

    default_texture = cast("int", DEFAULT_WORKSPACE_THEME["texture"])
    texture_obj = theme_map.get("texture", default_texture)
    if (
        not isinstance(texture_obj, int)
        or isinstance(texture_obj, bool)
        or texture_obj < 0
    ):
        texture_obj = default_texture

    return WorkspaceThemeSpec(
        type=theme_type_obj.strip(),
        gradient_colors=gradient_colors,
        opacity=float(opacity_obj),
        texture=texture_obj,
    )


def create_workspace_entry(spec: WorkspaceSpec) -> dict:
    """Construct a new workspace entry for the session file."""
    workspace = {
        "uuid": f"{{{uuidlib.uuid4()}}}",
        "name": spec.name,
        "theme": (
            spec.theme.to_session_dict()
            if spec.theme is not None
            else WorkspaceThemeSpec().to_session_dict()
        ),
        "containerTabId": spec.container_tab_id or 0,
        "hasCollapsedPinnedTabs": spec.has_collapsed_pinned_tabs or False,
    }
    if spec.icon:
        workspace["icon"] = spec.icon
    return workspace


def ensure_workspace(
    session: dict, spec: WorkspaceSpec
) -> tuple[str, WorkspaceSpec | None]:
    """Resolve a workspace, creating it in-session when missing."""
    existing = workspace_record_by_name(session, spec.name)
    if existing is not None:
        uuid = existing.get("uuid")
        if isinstance(uuid, str) and uuid:
            return uuid, None
        msg = f"Workspace '{spec.name}' exists but has no valid UUID."
        raise ZenFoldersError(msg)

    workspace = create_workspace_entry(spec)
    session.setdefault("spaces", []).append(workspace)
    return workspace["uuid"], spec


def plan_workspace_metadata_updates(
    plan: Plan,
    session: dict,
    workspace_uuid: str,
    spec: WorkspaceSpec,
) -> None:
    """Record safe workspace metadata updates and container-ID mismatches."""
    space = workspace_record_by_uuid(session, workspace_uuid)
    if not isinstance(space, dict):
        return

    current_icon = space.get("icon") if isinstance(space.get("icon"), str) else None
    if spec.icon is not None and current_icon != spec.icon:
        plan.workspace_updates.append(
            f"icon: {current_icon or '<unset>'} -> {spec.icon}"
        )

    if spec.theme is not None:
        current_theme = workspace_theme_from_record(space)
        if current_theme != spec.theme:
            plan.workspace_updates.append(
                "theme: "
                f"{current_theme.to_config_dict()} -> {spec.theme.to_config_dict()}"
            )

    if spec.has_collapsed_pinned_tabs is not None:
        current_collapsed = workspace_has_collapsed_pinned_tabs(space)
        if current_collapsed != spec.has_collapsed_pinned_tabs:
            plan.workspace_updates.append(
                "hasCollapsedPinnedTabs: "
                f"{current_collapsed} -> {spec.has_collapsed_pinned_tabs}"
            )

    if spec.container_tab_id is not None:
        current_container_tab_id = workspace_container_tab_id(session, workspace_uuid)
        if current_container_tab_id != spec.container_tab_id:
            plan.warnings.append(
                f"Workspace '{spec.name}' has containerTabId "
                f"{current_container_tab_id}, but config requests "
                f"{spec.container_tab_id}. zen-folders does not rewrite "
                "container IDs for existing workspaces; recreate the "
                "workspace if you need to change it."
            )


def apply_workspace_metadata(
    session: dict,
    workspace_uuid: str,
    spec: WorkspaceSpec,
) -> None:
    """Apply safe workspace metadata updates for an existing workspace."""
    space = workspace_record_by_uuid(session, workspace_uuid)
    if not isinstance(space, dict):
        return

    if spec.icon is not None:
        space["icon"] = spec.icon
    if spec.theme is not None:
        space["theme"] = spec.theme.to_session_dict()
    if spec.has_collapsed_pinned_tabs is not None:
        space["hasCollapsedPinnedTabs"] = spec.has_collapsed_pinned_tabs


def resolve_workspace(session: dict, name: str) -> str:
    """Resolve a workspace name to its UUID. Falls back to treating name as UUID."""
    existing = workspace_record_by_name(session, name)
    if existing is not None:
        uuid = existing.get("uuid")
        if isinstance(uuid, str) and uuid:
            return uuid

    # Maybe it's already a UUID
    if name.startswith("{") and name.endswith("}"):
        return name

    # List available workspaces for the error message
    available = []
    for space in session.get("spaces", []):
        if isinstance(space, dict):
            sname = space.get("name")
            if isinstance(sname, str):
                available.append(sname)
    avail_str = ", ".join(available) if available else "<none found>"
    msg = f"Workspace '{name}' not found. Available: {avail_str}"
    raise ZenFoldersError(msg)


def workspace_name(session: dict, uuid: str) -> str:
    """Resolve a workspace UUID to its name."""
    for space in session.get("spaces", []):
        if not isinstance(space, dict):
            continue
        if space.get("uuid") == uuid:
            name = space.get("name")
            if isinstance(name, str):
                return name
    return uuid


def folder_matches_workspace(folder: dict, workspace: str) -> bool:
    """Return whether a folder belongs to the workspace scope."""
    workspace_id = folder.get("workspaceId")
    return workspace_id is None or workspace_id == workspace


def folders_for_workspace(session: dict, workspace: str) -> list[dict]:
    """Return all folder entries visible in the given workspace."""
    return [
        folder
        for folder in session.get("folders", [])
        if isinstance(folder, dict) and folder_matches_workspace(folder, workspace)
    ]


def zen_profile_dir(profile: str | None) -> Path:
    """Resolve a profile argument to the profile directory path."""
    return resolve_profile_dir(profile)


def zen_lock_paths(profile: str | None) -> list[Path]:
    """Return existing profile lock-file paths for one Zen profile."""
    profile_dir = zen_profile_dir(profile)
    return [
        profile_dir / name
        for name in PROFILE_LOCK_FILENAMES
        if (profile_dir / name).exists()
    ]


def _lock_probe_state(path: Path) -> bool | None:
    """Return whether *path* appears actively locked, if probeable."""
    if fcntl is None:
        return None

    try:
        fd = os.open(path, os.O_RDWR)
    except OSError:
        return None

    locked = False
    try:
        try:
            fcntl.lockf(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except OSError as exc:
            if exc.errno in (errno.EACCES, errno.EAGAIN):
                locked = True
            else:
                return None
        else:
            with contextlib.suppress(OSError):
                fcntl.lockf(fd, fcntl.LOCK_UN)
        return locked
    finally:
        os.close(fd)


def zen_profile_lock_state(profile: str | None) -> bool | None:
    """Return whether the target profile lock appears active."""
    locks = zen_lock_paths(profile)
    if not locks:
        return False

    saw_unknown = False
    for path in locks:
        state = _lock_probe_state(path)
        if state is True:
            return True
        if state is None:
            saw_unknown = True
    if saw_unknown:
        return None
    return False


def zen_process_is_running() -> bool | None:
    """Best-effort detection of a running Zen/Twilight GUI process."""
    try:
        result = subprocess.run(
            ["/bin/ps", "ax", "-o", "command="],
            check=True,
            capture_output=True,
            text=True,
        )
    except (FileNotFoundError, subprocess.SubprocessError, OSError):
        return None

    for line in result.stdout.splitlines():
        command = line.strip().casefold()
        if not command:
            continue
        if ".app/contents/macos/zen" in command:
            return True
    return False


def inspect_zen_runtime(profile: str | None) -> ZenRuntimeState:
    """Inspect runtime state and preserve any detection uncertainty."""
    lock_paths = zen_lock_paths(profile)
    lock_state = zen_profile_lock_state(profile)
    if lock_state is not None:
        return ZenRuntimeState(running=lock_state)

    warnings = [
        "Could not confirm whether the profile lock is active; falling back to "
        "process inspection."
    ]
    process_state = zen_process_is_running()
    if process_state is not None:
        return ZenRuntimeState(running=process_state, warnings=tuple(warnings))

    warnings.append(
        "Could not inspect Zen processes either; treating existing profile lock "
        f"files as {'active' if lock_paths else 'inactive'}."
    )
    return ZenRuntimeState(running=bool(lock_paths), warnings=tuple(warnings))


def zen_is_running(profile: str | None) -> bool:
    """Detect whether Zen appears to be actively using the target profile."""
    return inspect_zen_runtime(profile).running


def _print_runtime_warnings(state: ZenRuntimeState) -> None:
    """Render runtime-detection warnings to stderr."""
    for warning in state.warnings:
        _stderr(f"Warning: {warning}")


def require_zen_closed(profile: str | None) -> ZenRuntimeState:
    """Abort when Zen is currently running against the target profile."""
    path = session_file(profile)
    state = inspect_zen_runtime(profile)
    if state.running:
        msg = f"Zen is running. Quit it first. (It may overwrite {path.name} on exit.)"
        if state.warnings:
            msg = f"{msg} Detection details: {' '.join(state.warnings)}"
        raise ZenFoldersError(
            msg,
        )
    return state


def backup_session(path: Path) -> Path:
    """Create a timestamped backup alongside the session file."""
    ts = time.strftime("%Y%m%d-%H%M%S")
    ns = time.time_ns() % 1_000_000_000
    stem = f"{path.name}.{ts}-{ns:09d}"

    bak = path.with_name(f"{stem}.bak")
    suffix = 0
    while bak.exists():
        suffix += 1
        bak = path.with_name(f"{stem}.{suffix}.bak")

    try:
        shutil.copy2(path, bak)
    except OSError as exc:
        msg = f"Failed to create backup {bak.name}: {exc}"
        raise ZenFoldersError(msg) from exc
    return bak


def collect_sync_ids(session: dict) -> set[str]:
    """Collect all existing sync/group/folder IDs used in session data."""
    existing: set[str] = set()

    for group in session.get("groups", []):
        if isinstance(group, dict):
            gid = group.get("id")
            if isinstance(gid, str) and gid:
                existing.add(gid)

    for folder in session.get("folders", []):
        if isinstance(folder, dict):
            fid = folder.get("id")
            if isinstance(fid, str) and fid:
                existing.add(fid)

    for tab in session.get("tabs", []):
        if isinstance(tab, dict):
            sync_id = tab.get("zenSyncId")
            if isinstance(sync_id, str) and sync_id:
                existing.add(sync_id)

    return existing


def next_sync_id(existing: set[str]) -> str:
    """Generate a unique sync identifier not present in *existing*."""
    base_ms = int(time.time_ns() // 1_000_000)
    for offset in range(MAX_ID_ATTEMPTS):
        stamp = base_ms + offset
        candidate = f"{stamp}-{offset % 1000}"
        if candidate not in existing:
            existing.add(candidate)
            return candidate
    msg = "Unable to generate a unique sync ID."
    raise ZenFoldersError(msg)


def folder_by_name(session: dict, name: str, workspace: str) -> dict | None:
    """Find one folder by name within a workspace, or return ``None``."""
    name_cf = name.casefold()
    matches: list[dict] = []
    for folder in folders_for_workspace(session, workspace):
        folder_name = folder.get("name")
        if isinstance(folder_name, str) and folder_name.casefold() == name_cf:
            matches.append(folder)

    if len(matches) > 1:
        msg = (
            f"Multiple folders named '{name}' in this workspace. "
            "Rename duplicates manually in Zen first."
        )
        raise ZenFoldersError(
            msg,
        )
    return matches[0] if matches else None


def group_by_id(session: dict, gid: str) -> dict | None:
    """Return the first group object matching *gid*."""
    for group in session.get("groups", []):
        if isinstance(group, dict) and group.get("id") == gid:
            return group
    return None


def pinned_tabs(session: dict, workspace: str) -> list[dict]:
    """Return pinned, non-placeholder tabs for one workspace."""
    tabs: list[dict] = []
    for tab in session.get("tabs", []):
        if not isinstance(tab, dict):
            continue
        if (
            tab.get("pinned")
            and tab.get("zenWorkspace") == workspace
            and not tab.get("zenIsEmpty")
        ):
            tabs.append(tab)
    return tabs


def folder_tabs(
    session: dict, folder_id: str, workspace: str | None = None
) -> list[dict]:
    """Return non-placeholder tabs currently assigned to a folder."""
    tabs: list[dict] = []
    for tab in session.get("tabs", []):
        if not isinstance(tab, dict):
            continue
        if tab.get("groupId") != folder_id or tab.get("zenIsEmpty"):
            continue
        if workspace is not None and tab.get("zenWorkspace") != workspace:
            continue
        tabs.append(tab)
    return tabs


def folder_display_name(folder: dict) -> str:
    """Return a human label for a folder record."""
    name = folder.get("name")
    return name if isinstance(name, str) and name else "<unnamed>"


def is_placeholder_tab(tab: dict, folder_id: str, empty_ids: set[str]) -> bool:
    """Return whether *tab* is the designated placeholder for *folder_id*."""
    if tab.get("groupId") != folder_id:
        return False
    if not tab.get("zenIsEmpty"):
        return False
    if not empty_ids:
        return True
    sync_id = tab.get("zenSyncId")
    return isinstance(sync_id, str) and sync_id in empty_ids


def match_tab_by_url(tab: dict, pattern: str) -> bool:
    """Case-insensitive URL substring match."""
    return pattern.casefold() in tab_url(tab).casefold()


def pattern_to_tab_url(pattern: str) -> str:
    """Convert a URL pattern into a navigable URL for tab creation."""
    value = pattern.strip()
    if value.startswith(("http://", "https://")):
        return value
    if value.startswith("//"):
        return f"https:{value}"
    return f"https://{value}"


def make_pinned_tab(
    url: str,
    title: str,
    workspace_uuid: str,
    folder_id: str,
    sync_id: str,
    user_context_id: int = 0,
) -> dict:
    """Construct a new pinned tab payload for insertion into session JSON."""
    return {
        "entries": [{"url": url, "title": title}],
        "index": 1,
        "lastAccessed": int(time.time_ns() // 1_000_000),
        "hidden": False,
        "pinned": True,
        "zenWorkspace": workspace_uuid,
        "zenSyncId": sync_id,
        "groupId": folder_id,
        "searchMode": 0,
        "userContextId": user_context_id,
    }


# -- Reconciliation engine ----------------------------------------------------


class Plan:
    """Describes changes needed to reconcile session with YAML config."""

    def __init__(self) -> None:
        """Initialize empty change collections for one reconciliation run."""
        self.workspace_to_create: WorkspaceSpec | None = None
        self.workspace_updates: list[str] = []
        self.folders_to_create: list[str] = []  # names
        self.folders_to_delete: list[str] = []  # names
        self.tabs_to_create: list[tuple[str, str]] = []  # (url_preview, folder)
        self.tab_moves: list[tuple[str, str | None, str]] = []
        self.tab_ungroups: list[tuple[str, str]] = []  # (url_preview, old_folder)
        self.reorder_folders: bool = False
        self.reorder_tabs: dict[str, bool] = {}  # folder_name -> needs reorder
        self.warnings: list[str] = []

    @property
    def has_changes(self) -> bool:
        """Return whether this plan has any data-mutating operations."""
        return bool(
            self.workspace_to_create
            or self.workspace_updates
            or self.folders_to_create
            or self.folders_to_delete
            or self.tabs_to_create
            or self.tab_moves
            or self.tab_ungroups
            or self.reorder_folders
            or any(self.reorder_tabs.values())
        )


@dataclass
class _PlanTabContext:
    """Shared mutable state used while planning folder tab actions."""

    session: dict
    workspace_uuid: str
    all_pinned: list[dict]
    folder_id_to_name: dict[str, str]
    claimed_tab_indices: set[int]


@dataclass
class _AssignTabContext:
    """Shared mutable state used while assigning tabs during apply."""

    session: dict
    all_pinned: list[dict]
    workspace_uuid: str
    existing_ids: set[str]
    claimed_tab_indices: set[int]


def _build_session_folder_map(session_folders: list[dict]) -> dict[str, dict]:
    """Map lowercased folder names to folder objects, rejecting duplicates."""
    session_folder_map: dict[str, dict] = {}
    for folder in session_folders:
        name = folder_display_name(folder)
        name_cf = name.casefold()
        if name_cf in session_folder_map:
            msg = (
                f"Workspace has duplicate folder names matching '{name}' "
                "(case-insensitive). Rename duplicates in Zen first."
            )
            raise ZenFoldersError(msg)
        session_folder_map[name_cf] = folder
    return session_folder_map


def _config_folder_data(
    config_folders: list[dict],
) -> tuple[list[str], dict[str, list[dict]]]:
    """Return ordered folder names and tab specs keyed by casefolded name."""
    config_folder_names: list[str] = []
    config_folder_tabs: dict[str, list[dict]] = {}
    for folder in config_folders:
        name = folder["name"].strip()
        config_folder_names.append(name)
        config_folder_tabs[name.casefold()] = folder.get("tabs") or []
    return config_folder_names, config_folder_tabs


def _plan_folder_presence(
    plan: Plan,
    config_folder_names: list[str],
    session_folder_map: dict[str, dict],
) -> None:
    """Populate folder create/delete lists on the plan."""
    config_names_cf = {name.casefold() for name in config_folder_names}
    session_names_cf = set(session_folder_map.keys())

    for name in config_folder_names:
        if name.casefold() not in session_names_cf:
            plan.folders_to_create.append(name)

    for name_cf, folder in session_folder_map.items():
        if name_cf not in config_names_cf:
            plan.folders_to_delete.append(folder_display_name(folder))


def _plan_folder_order(
    plan: Plan,
    session_folders: list[dict],
    config_folder_names: list[str],
    session_folder_map: dict[str, dict],
) -> None:
    """Mark whether folder ordering must be updated."""
    config_names_cf = {name.casefold() for name in config_folder_names}
    session_names_cf = set(session_folder_map.keys())
    session_order = [
        folder_display_name(folder) for folder in _ordered_folders(session_folders)
    ]
    existing_session_order = [
        name for name in session_order if name.casefold() in config_names_cf
    ]
    existing_config_order = [
        name for name in config_folder_names if name.casefold() in session_names_cf
    ]
    if [name.casefold() for name in existing_session_order] != [
        name.casefold() for name in existing_config_order
    ]:
        plan.reorder_folders = True


def _folder_name_by_id(session_folders: list[dict]) -> dict[str, str]:
    """Return mapping from folder/group ID to display name."""
    mapping: dict[str, str] = {}
    for folder in session_folders:
        folder_id = folder.get("id")
        if isinstance(folder_id, str):
            mapping[folder_id] = folder_display_name(folder)
    return mapping


def _find_tab_matches(all_pinned: list[dict], pattern: str) -> list[tuple[int, dict]]:
    """Return all pinned tabs whose URL matches *pattern*."""
    return [
        (index, tab)
        for index, tab in enumerate(all_pinned)
        if match_tab_by_url(tab, pattern)
    ]


def _first_unclaimed_match(
    matches: list[tuple[int, dict]],
    claimed_tab_indices: set[int],
) -> tuple[int, dict] | None:
    """Return the first match that is not already claimed."""
    for index, tab in matches:
        if index not in claimed_tab_indices:
            return index, tab
    return None


def _needs_folder_tab_reorder(
    session: dict,
    workspace_uuid: str,
    session_folder_id: object,
    desired_urls_ordered: list[str],
) -> bool:
    """Return whether tab order differs from desired order for one folder."""
    if not isinstance(session_folder_id, str) or not desired_urls_ordered:
        return False
    current_urls = [
        tab_url(tab).casefold()
        for tab in folder_tabs(session, session_folder_id, workspace_uuid)
    ]
    desired_set = set(desired_urls_ordered)
    current_in_desired = [url for url in current_urls if url in desired_set]
    return current_in_desired != desired_urls_ordered


def _plan_tabs_for_folder(
    plan: Plan,
    context: _PlanTabContext,
    folder_name: str,
    tab_specs: list[dict],
    session_folder: dict | None,
) -> None:
    """Plan tab creation/moves/order for one configured folder."""
    desired_urls_ordered: list[str] = []
    session_folder_id = session_folder.get("id") if session_folder else None

    for spec in tab_specs:
        pattern = spec["url"].strip()
        target_url = pattern_to_tab_url(pattern)
        matches = _find_tab_matches(context.all_pinned, pattern)
        if not matches:
            plan.tabs_to_create.append((target_url[:70], folder_name))
            desired_urls_ordered.append(target_url.casefold())
            continue

        if len(matches) > 1:
            warning = (
                f"Pattern '{pattern}' matches {len(matches)} tabs for folder "
                f"'{folder_name}'; using first match"
            )
            plan.warnings.append(warning)

        chosen = _first_unclaimed_match(matches, context.claimed_tab_indices)
        if chosen is None:
            plan.tabs_to_create.append((target_url[:70], folder_name))
            desired_urls_ordered.append(target_url.casefold())
            continue

        index, tab = chosen
        context.claimed_tab_indices.add(index)
        preview_url = tab_url(tab)
        desired_urls_ordered.append(preview_url.casefold())

        group_id = tab.get("groupId")
        current_folder_name = (
            context.folder_id_to_name.get(group_id)
            if isinstance(group_id, str)
            else None
        )
        if (
            current_folder_name
            and current_folder_name.casefold() == folder_name.casefold()
        ):
            continue
        plan.tab_moves.append((preview_url[:70], current_folder_name, folder_name))

    if _needs_folder_tab_reorder(
        context.session,
        context.workspace_uuid,
        session_folder_id,
        desired_urls_ordered,
    ):
        plan.reorder_tabs[folder_name] = True


def _plan_ungrouped_tabs(
    plan: Plan,
    all_pinned: list[dict],
    claimed_tab_indices: set[int],
    folder_id_to_name: dict[str, str],
    config_names_cf: set[str],
) -> None:
    """Plan tabs that should be ungrouped because config no longer claims them."""
    for index, tab in enumerate(all_pinned):
        if index in claimed_tab_indices:
            continue
        group_id = tab.get("groupId")
        if not isinstance(group_id, str):
            continue
        current_folder_name = folder_id_to_name.get(group_id)
        if current_folder_name is None:
            continue
        if current_folder_name.casefold() not in config_names_cf:
            continue
        plan.tab_ungroups.append((tab_url(tab)[:70], current_folder_name))


def compute_plan(
    session: dict,
    config_folders: list[dict],
    workspace_uuid: str,
) -> Plan:
    """Compare session state against YAML config and produce a reconciliation plan."""
    plan = Plan()
    session_folders = folders_for_workspace(session, workspace_uuid)
    session_folder_map = _build_session_folder_map(session_folders)
    config_folder_names, config_folder_tabs = _config_folder_data(config_folders)

    _plan_folder_presence(plan, config_folder_names, session_folder_map)
    _plan_folder_order(plan, session_folders, config_folder_names, session_folder_map)

    plan_context = _PlanTabContext(
        session=session,
        workspace_uuid=workspace_uuid,
        all_pinned=pinned_tabs(session, workspace_uuid),
        folder_id_to_name=_folder_name_by_id(session_folders),
        claimed_tab_indices=set(),
    )
    for folder_name in config_folder_names:
        _plan_tabs_for_folder(
            plan,
            plan_context,
            folder_name,
            config_folder_tabs[folder_name.casefold()],
            session_folder_map.get(folder_name.casefold()),
        )

    config_names_cf = {name.casefold() for name in config_folder_names}
    _plan_ungrouped_tabs(
        plan,
        plan_context.all_pinned,
        plan_context.claimed_tab_indices,
        plan_context.folder_id_to_name,
        config_names_cf,
    )
    return plan


def _folder_chain_maps(
    folders: list[dict],
) -> tuple[dict | None, dict[str | None, dict]]:
    """Build start pointer and next-folder mapping from sibling metadata."""
    start_folder: dict | None = None
    after_map: dict[str | None, dict] = {}
    for folder in folders:
        prev = folder.get("prevSiblingInfo")
        if isinstance(prev, dict):
            if prev.get("type") == "start":
                start_folder = folder
                after_map[None] = folder
            else:
                after_map[prev.get("id")] = folder
        elif start_folder is None:
            start_folder = folder
            after_map[None] = folder
    return start_folder, after_map


def _walk_folder_chain(
    start_folder: dict | None,
    after_map: dict[str | None, dict],
    max_items: int,
) -> tuple[list[dict], set[str]]:
    """Walk the folder chain from the start sentinel."""
    ordered: list[dict] = []
    visited: set[str] = set()
    current = start_folder
    while current is not None and len(ordered) < max_items:
        folder_id = current.get("id")
        if isinstance(folder_id, str):
            if folder_id in visited:
                break
            visited.add(folder_id)
        ordered.append(current)
        current = after_map.get(folder_id)
    return ordered, visited


def _ordered_folders(folders: list[dict]) -> list[dict]:
    """Sort folders by their ``prevSiblingInfo`` chain."""
    if not folders:
        return []
    start_folder, after_map = _folder_chain_maps(folders)
    ordered, visited = _walk_folder_chain(
        start_folder, after_map, max_items=len(folders)
    )
    for folder in folders:
        folder_id = folder.get("id")
        if isinstance(folder_id, str) and folder_id not in visited:
            ordered.append(folder)
    return ordered


def _delete_folder(session: dict, folder_id: str, empty_ids: set[str]) -> None:
    """Remove one folder and ungroup/delete all related tabs."""
    for tab in session["tabs"]:
        if (
            isinstance(tab, dict)
            and tab.get("groupId") == folder_id
            and not tab.get("zenIsEmpty")
        ):
            tab.pop("groupId", None)

    session["tabs"] = [
        tab
        for tab in session["tabs"]
        if not (isinstance(tab, dict) and is_placeholder_tab(tab, folder_id, empty_ids))
    ]
    session["groups"] = [
        group
        for group in session["groups"]
        if not (isinstance(group, dict) and group.get("id") == folder_id)
    ]
    session["folders"] = [
        folder
        for folder in session["folders"]
        if not (isinstance(folder, dict) and folder.get("id") == folder_id)
    ]


def _delete_removed_folders(
    session: dict, workspace_uuid: str, folder_names: list[str]
) -> None:
    """Delete folders that are no longer present in config."""
    for name in folder_names:
        folder = folder_by_name(session, name, workspace_uuid)
        if not folder:
            continue
        folder_id = folder.get("id")
        if not isinstance(folder_id, str):
            continue
        raw_empty_ids = folder.get("emptyTabIds", [])
        empty_ids = {item for item in raw_empty_ids if isinstance(item, str) and item}
        _delete_folder(session, folder_id, empty_ids)


def _create_folder(
    session: dict, workspace_uuid: str, name: str, existing_ids: set[str]
) -> None:
    """Create a folder plus group and placeholder tab entries."""
    folder_id = next_sync_id(existing_ids)
    empty_id = next_sync_id(existing_ids)
    user_context_id = workspace_container_tab_id(session, workspace_uuid)
    session["tabs"].append({
        "entries": [],
        "lastAccessed": 0,
        "hidden": False,
        "pinned": True,
        "zenWorkspace": workspace_uuid,
        "zenSyncId": empty_id,
        "groupId": folder_id,
        "zenIsEmpty": True,
        "searchMode": 0,
        "userContextId": user_context_id,
    })
    session["groups"].append({
        "pinned": True,
        "splitView": False,
        "id": folder_id,
        "name": name,
        "color": GROUP_COLOR,
        "collapsed": False,
        "saveOnWindowClose": True,
    })
    session["folders"].append({
        "pinned": True,
        "essential": False,
        "splitViewGroup": False,
        "id": folder_id,
        "name": name,
        "collapsed": False,
        "saveOnWindowClose": True,
        "parentId": None,
        "prevSiblingInfo": {"type": "start", "id": None},
        "emptyTabIds": [empty_id],
        "userIcon": "",
        "workspaceId": workspace_uuid,
    })


def _create_missing_folders(
    session: dict,
    workspace_uuid: str,
    folder_names: list[str],
    existing_ids: set[str],
) -> None:
    """Create all folders listed by the plan as missing."""
    for name in folder_names:
        _create_folder(session, workspace_uuid, name, existing_ids)


def _folder_name_to_id(session: dict, workspace_uuid: str) -> dict[str, str]:
    """Map casefolded folder names to IDs for a workspace."""
    mapping: dict[str, str] = {}
    for folder in folders_for_workspace(session, workspace_uuid):
        folder_id = folder.get("id")
        if isinstance(folder_id, str):
            mapping[folder_display_name(folder).casefold()] = folder_id
    return mapping


def _assign_tabs_for_folder(
    context: _AssignTabContext,
    folder_id: str,
    tab_specs: list[dict],
) -> list[dict]:
    """Assign/create tabs for one folder and return desired tab order."""
    ordered_tabs: list[dict] = []
    for spec in tab_specs:
        pattern = spec["url"].strip()
        target_url = pattern_to_tab_url(pattern)
        target_title = spec.get("title", "")
        if not isinstance(target_title, str) or not target_title.strip():
            target_title = target_url

        matches = _find_tab_matches(context.all_pinned, pattern)
        chosen = _first_unclaimed_match(matches, context.claimed_tab_indices)
        if chosen is None:
            tab = make_pinned_tab(
                url=target_url,
                title=target_title.strip(),
                workspace_uuid=context.workspace_uuid,
                folder_id=folder_id,
                sync_id=next_sync_id(context.existing_ids),
                user_context_id=workspace_container_tab_id(
                    context.session, context.workspace_uuid
                ),
            )
            context.session["tabs"].append(tab)
            context.all_pinned.append(tab)
            chosen = (len(context.all_pinned) - 1, tab)

        index, tab = chosen
        context.claimed_tab_indices.add(index)
        tab["groupId"] = folder_id
        ordered_tabs.append(tab)
    return ordered_tabs


def _assign_tabs_to_folders(
    session: dict,
    config_folders: list[dict],
    workspace_uuid: str,
    existing_ids: set[str],
) -> tuple[dict[str, list[dict]], list[dict], set[int]]:
    """Assign all configured tabs and return desired ordering structures."""
    all_pinned = pinned_tabs(session, workspace_uuid)
    folder_name_to_id = _folder_name_to_id(session, workspace_uuid)
    desired_tab_order: dict[str, list[dict]] = {}
    apply_context = _AssignTabContext(
        session=session,
        all_pinned=all_pinned,
        workspace_uuid=workspace_uuid,
        existing_ids=existing_ids,
        claimed_tab_indices=set(),
    )

    for folder_spec in config_folders:
        folder_name = folder_spec["name"].strip()
        folder_id = folder_name_to_id.get(folder_name.casefold())
        if not folder_id:
            continue
        tab_specs = folder_spec.get("tabs") or []
        desired_tab_order[folder_id] = _assign_tabs_for_folder(
            apply_context,
            folder_id,
            tab_specs,
        )

    return desired_tab_order, all_pinned, apply_context.claimed_tab_indices


def _ungroup_unclaimed_tabs(
    session: dict,
    config_folders: list[dict],
    workspace_uuid: str,
    all_pinned: list[dict],
    claimed_tab_indices: set[int],
) -> None:
    """Ungroup tabs left in configured folders that are no longer claimed."""
    config_names_cf = {folder["name"].strip().casefold() for folder in config_folders}
    workspace_folders = folders_for_workspace(session, workspace_uuid)
    for index, tab in enumerate(all_pinned):
        if index in claimed_tab_indices:
            continue
        group_id = tab.get("groupId")
        if not isinstance(group_id, str):
            continue
        for folder in workspace_folders:
            if folder.get("id") != group_id:
                continue
            if folder_display_name(folder).casefold() in config_names_cf:
                tab.pop("groupId", None)
            break


def _rebuild_folder_and_group_order(
    session: dict,
    config_folders: list[dict],
    workspace_uuid: str,
) -> list[dict]:
    """Rewrite workspace folder/group arrays to match config ordering."""
    workspace_folders = folders_for_workspace(session, workspace_uuid)
    config_name_order = {
        folder["name"].strip().casefold(): index
        for index, folder in enumerate(config_folders)
    }
    workspace_folders.sort(
        key=lambda folder: config_name_order.get(
            folder_display_name(folder).casefold(), 999
        )
    )

    prev_id: str | None = None
    for folder in workspace_folders:
        if prev_id is None:
            folder["prevSiblingInfo"] = {"type": "start", "id": None}
        else:
            folder["prevSiblingInfo"] = {"type": "group", "id": prev_id}
        folder_id = folder.get("id")
        prev_id = folder_id if isinstance(folder_id, str) else None

    workspace_folder_ids = {id(folder) for folder in workspace_folders}
    other_folders = [
        folder
        for folder in session["folders"]
        if id(folder) not in workspace_folder_ids
    ]
    session["folders"] = workspace_folders + other_folders

    workspace_group_ids = {
        folder_id
        for folder_id in (folder.get("id") for folder in workspace_folders)
        if isinstance(folder_id, str)
    }
    workspace_groups: list[dict] = []
    for folder in workspace_folders:
        folder_id = folder.get("id")
        for group in session["groups"]:
            if isinstance(group, dict) and group.get("id") == folder_id:
                workspace_groups.append(group)
                break
    other_groups = [
        group
        for group in session["groups"]
        if not isinstance(group, dict) or group.get("id") not in workspace_group_ids
    ]
    session["groups"] = workspace_groups + other_groups
    return workspace_folders


def _reorder_tabs_within_folders(
    session: dict, desired_tab_order: dict[str, list[dict]]
) -> None:
    """Reorder tabs inside each folder block according to desired order."""
    for folder_id, ordered_tabs in desired_tab_order.items():
        if not ordered_tabs:
            continue
        ordered_ids = {id(tab) for tab in ordered_tabs}
        placeholder_tabs = [
            tab
            for tab in session["tabs"]
            if isinstance(tab, dict)
            and tab.get("groupId") == folder_id
            and tab.get("zenIsEmpty")
        ]
        all_folder_tab_ids = ordered_ids | {id(tab) for tab in placeholder_tabs}
        remaining_tabs = [
            tab for tab in session["tabs"] if id(tab) not in all_folder_tab_ids
        ]

        insert_at = len(remaining_tabs)
        for index, tab in enumerate(session["tabs"]):
            if id(tab) in all_folder_tab_ids:
                insert_at = sum(
                    1
                    for prior_tab in session["tabs"][:index]
                    if id(prior_tab) not in all_folder_tab_ids
                )
                break

        session["tabs"] = (
            remaining_tabs[:insert_at]
            + placeholder_tabs
            + ordered_tabs
            + remaining_tabs[insert_at:]
        )


def _reorder_workspace_folder_blocks(
    session: dict, workspace_folders: list[dict]
) -> None:
    """Reorder tab blocks so workspace folders render in config order."""
    workspace_folder_ids = [
        folder_id
        for folder_id in (folder.get("id") for folder in workspace_folders)
        if isinstance(folder_id, str)
    ]
    workspace_folder_id_set = set(workspace_folder_ids)

    unfiled_pinned: list[object] = []
    folder_blocks: dict[str, list[dict]] = {
        folder_id: [] for folder_id in workspace_folder_ids
    }
    unpinned: list[object] = []

    for tab in session["tabs"]:
        if not isinstance(tab, dict):
            unpinned.append(tab)
            continue
        group_id = tab.get("groupId")
        if isinstance(group_id, str) and group_id in workspace_folder_id_set:
            folder_blocks[group_id].append(tab)
        elif tab.get("pinned"):
            unfiled_pinned.append(tab)
        else:
            unpinned.append(tab)

    rebuilt_tabs: list[object] = list(unfiled_pinned)
    for folder_id in workspace_folder_ids:
        rebuilt_tabs.extend(folder_blocks[folder_id])
    rebuilt_tabs.extend(unpinned)
    session["tabs"] = rebuilt_tabs


def apply_plan(
    session: dict,
    config_folders: list[dict],
    workspace_uuid: str,
    plan: Plan,
) -> None:
    """Mutate session in-place to match the planned configuration."""
    existing_ids = collect_sync_ids(session)
    _delete_removed_folders(session, workspace_uuid, plan.folders_to_delete)
    _create_missing_folders(
        session, workspace_uuid, plan.folders_to_create, existing_ids
    )

    desired_tab_order, all_pinned, claimed_tab_indices = _assign_tabs_to_folders(
        session,
        config_folders,
        workspace_uuid,
        existing_ids,
    )
    _ungroup_unclaimed_tabs(
        session,
        config_folders,
        workspace_uuid,
        all_pinned,
        claimed_tab_indices,
    )

    workspace_folders = _rebuild_folder_and_group_order(
        session,
        config_folders,
        workspace_uuid,
    )
    _reorder_tabs_within_folders(session, desired_tab_order)
    _reorder_workspace_folder_blocks(session, workspace_folders)


def reconcile_workspace(
    session: dict,
    config_folders: list[dict],
    workspace_uuid: str,
    workspace_spec: WorkspaceSpec,
    plan: Plan,
) -> None:
    """Apply workspace metadata and folder reconciliation in the required order."""
    # New tabs inherit workspace-level metadata such as container IDs, so apply
    # those updates before creating or moving any pinned tabs.
    apply_workspace_metadata(session, workspace_uuid, workspace_spec)
    apply_plan(session, config_folders, workspace_uuid, plan)


# -- Commands -----------------------------------------------------------------


def _print_lines(lines: list[str]) -> None:
    """Write one line per item to stdout."""
    for line in lines:
        _stdout(line)


def _plan_summary_parts(plan: Plan) -> list[str]:
    """Build a short human summary of plan operations."""
    parts: list[str] = []
    if plan.workspace_to_create is not None:
        parts.append(f"create workspace '{plan.workspace_to_create.name}'")
    if plan.workspace_updates:
        parts.append("update workspace metadata")
    if plan.folders_to_create:
        parts.append(f"create {len(plan.folders_to_create)} folder(s)")
    if plan.folders_to_delete:
        parts.append(f"delete {len(plan.folders_to_delete)} folder(s)")
    if plan.tabs_to_create:
        parts.append(f"create {len(plan.tabs_to_create)} tab(s)")
    if plan.tab_moves:
        parts.append(f"move {len(plan.tab_moves)} tab(s)")
    if plan.tab_ungroups:
        parts.append(f"ungroup {len(plan.tab_ungroups)} tab(s)")
    if plan.reorder_folders:
        parts.append("reorder folders")
    reordered = [name for name, needs in plan.reorder_tabs.items() if needs]
    if reordered:
        parts.append(f"reorder tabs in {len(reordered)} folder(s)")
    return parts


def _print_plan_warnings(plan: Plan) -> None:
    """Render plan warnings to stdout."""
    if not plan.warnings:
        return
    _stdout("Warnings:")
    for warning in plan.warnings:
        _stdout(f"  ! {warning}")
    _stdout()


def _print_plan_collection(title: str, prefix: str, items: list[str]) -> None:
    """Render a titled list using one prefixed line per item."""
    if not items:
        return
    _stdout(title)
    for item in items:
        _stdout(f"  {prefix} {item}")
    _stdout()


def _print_workspace_updates(updates: list[str]) -> None:
    """Render planned workspace metadata updates."""
    if not updates:
        return
    _stdout("Workspace metadata to update:")
    for item in updates:
        _stdout(f"  ~ {item}")
    _stdout()


def _print_tab_moves(tab_moves: list[tuple[str, str | None, str]]) -> None:
    """Render planned tab move operations."""
    if not tab_moves:
        return
    _stdout("Tab moves:")
    for url, old, new in tab_moves:
        _stdout(f"  {url}")
        _stdout(f"    {old or 'unfiled'} -> {new}")
    _stdout()


def _print_tabs_to_create(tabs_to_create: list[tuple[str, str]]) -> None:
    """Render planned tab creations."""
    if not tabs_to_create:
        return
    _stdout("Tabs to create:")
    for url, folder in tabs_to_create:
        _stdout(f"  + {url}")
        _stdout(f"    -> {folder}")
    _stdout()


def _print_tabs_to_ungroup(tab_ungroups: list[tuple[str, str]]) -> None:
    """Render planned tab ungroup operations."""
    if not tab_ungroups:
        return
    _stdout("Tabs to ungroup:")
    for url, old in tab_ungroups:
        _stdout(f"  {url}")
        _stdout(f"    {old} -> unfiled")
    _stdout()


def _print_reorder_details(plan: Plan) -> None:
    """Render folder/tab reorder details from a plan."""
    if plan.reorder_folders:
        _stdout("Folder order will be updated to match config.")
        _stdout()

    reordered = [name for name, needs in plan.reorder_tabs.items() if needs]
    if reordered:
        _stdout("Tab order will be updated in:")
        for name in reordered:
            _stdout(f"  ~ {name}")
        _stdout()


def _print_check_warnings(warnings: list[str]) -> None:
    """Render check warnings, if any."""
    if not warnings:
        return
    _stdout(f"Warnings ({len(warnings)}):")
    for warning in warnings:
        _stdout(f"  ~ {warning}")


def _has_placeholder_tab(session: dict, folder_id: str, empty_id: str) -> bool:
    """Return whether session contains a placeholder tab for one empty ID."""
    for tab in session.get("tabs", []):
        if not isinstance(tab, dict):
            continue
        if (
            tab.get("zenSyncId") == empty_id
            and tab.get("groupId") == folder_id
            and tab.get("zenIsEmpty")
        ):
            return True
    return False


def _check_folder_placeholders(
    session: dict,
    workspace_uuid: str,
    folder: dict,
    folder_id: str,
    name: str,
) -> tuple[list[str], list[str]]:
    """Validate placeholder IDs and tabs for one folder."""
    errors: list[str] = []
    warnings: list[str] = []
    raw_empty_ids = folder.get("emptyTabIds", [])
    if not isinstance(raw_empty_ids, list):
        return [f"Folder '{name}' has malformed emptyTabIds."], []

    empty_ids = [value for value in raw_empty_ids if isinstance(value, str) and value]
    has_real_tabs = bool(folder_tabs(session, folder_id, workspace_uuid))
    if not empty_ids:
        if has_real_tabs:
            warnings.append(
                f"Folder '{name}' has no placeholder tab IDs (has real tabs, benign)."
            )
        else:
            errors.append(
                f"Folder '{name}' has no placeholder tab IDs and no real tabs."
            )
        return errors, warnings

    errors.extend(
        f"Folder '{name}' references missing placeholder tab {empty_id}."
        for empty_id in empty_ids
        if not _has_placeholder_tab(session, folder_id, empty_id)
    )
    return errors, warnings


def _check_single_folder(
    session: dict,
    workspace_uuid: str,
    folder: dict,
) -> tuple[list[str], list[str], str | None]:
    """Validate one folder record and return its usable ID if present."""
    errors: list[str] = []
    warnings: list[str] = []
    name = folder_display_name(folder)
    folder_id = folder.get("id")
    if not isinstance(folder_id, str) or not folder_id:
        errors.append(f"Folder '{name}' has missing/invalid id.")
        return errors, warnings, None

    if group_by_id(session, folder_id) is None:
        errors.append(
            f"Folder '{name}' has no matching entry in groups (id={folder_id})."
        )

    placeholder_errors, placeholder_warnings = _check_folder_placeholders(
        session,
        workspace_uuid,
        folder,
        folder_id,
        name,
    )
    errors.extend(placeholder_errors)
    warnings.extend(placeholder_warnings)
    return errors, warnings, folder_id


def _check_folder_structures(
    session: dict,
    workspace_uuid: str,
    folders: list[dict],
) -> tuple[list[str], list[str], set[str]]:
    """Validate folder/group/placeholder consistency and collect IDs."""
    errors: list[str] = []
    warnings: list[str] = []
    folder_ids: set[str] = set()

    for folder in folders:
        folder_errors, folder_warnings, folder_id = _check_single_folder(
            session,
            workspace_uuid,
            folder,
        )
        errors.extend(folder_errors)
        warnings.extend(folder_warnings)
        if folder_id is None:
            continue
        if folder_id in folder_ids:
            errors.append(f"Duplicate folder id detected: {folder_id}.")
            continue
        folder_ids.add(folder_id)

    return errors, warnings, folder_ids


def _check_tab_group_refs(
    session: dict, workspace_uuid: str, folder_ids: set[str]
) -> list[str]:
    """Validate that pinned tabs reference known folder IDs."""
    errors: list[str] = []
    for tab in pinned_tabs(session, workspace_uuid):
        group_id = tab.get("groupId")
        if isinstance(group_id, str) and group_id and group_id not in folder_ids:
            url = tab_url(tab)[:70] or "<empty-url>"
            errors.append(
                f"Pinned tab '{url}' references unknown folder/group id {group_id}."
            )
    return errors


def cmd_list(args: argparse.Namespace) -> int:
    """List folders for one workspace, preserving render order."""
    _, session = load_session(args.profile)
    workspace_uuid = resolve_workspace(session, args.workspace)
    folders = folders_for_workspace(session, workspace_uuid)
    group_ids = {
        group["id"]
        for group in session.get("groups", [])
        if isinstance(group, dict) and isinstance(group.get("id"), str)
    }

    if not folders:
        _stdout(f"No folders in workspace {workspace_name(session, workspace_uuid)}.")
        return 0

    ordered = _ordered_folders(folders)
    for index, folder in enumerate(ordered):
        folder_id = folder.get("id")
        synced = (
            "ok"
            if isinstance(folder_id, str) and folder_id in group_ids
            else "NO GROUP"
        )
        members = (
            folder_tabs(session, folder_id, workspace_uuid)
            if isinstance(folder_id, str)
            else []
        )
        _stdout(
            f"{index + 1:2d}. {folder_display_name(folder)}  ({len(members)} tabs)  [{synced}]"
        )
        if args.verbose:
            for tab in members:
                _stdout(f"      {tab_url(tab)[:76]}")
    return 0


def cmd_tabs(args: argparse.Namespace) -> int:
    """List pinned tabs grouped by folder membership."""
    _, session = load_session(args.profile)
    workspace_uuid = resolve_workspace(session, args.workspace)
    tabs = pinned_tabs(session, workspace_uuid)

    folder_names = {
        folder["id"]: folder_display_name(folder)
        for folder in folders_for_workspace(session, workspace_uuid)
        if isinstance(folder.get("id"), str)
    }
    grouped: dict[str, list[dict]] = {}
    unfiled: list[dict] = []

    for tab in tabs:
        group_id = tab.get("groupId")
        if isinstance(group_id, str) and group_id in folder_names:
            grouped.setdefault(folder_names[group_id], []).append(tab)
        else:
            unfiled.append(tab)

    if unfiled:
        _stdout(f"Unfiled ({len(unfiled)}):")
        for tab in unfiled:
            essential = " [essential]" if tab.get("zenEssential") else ""
            _stdout(f"  {tab_url(tab)[:78]}{essential}")

    for name, members in sorted(grouped.items()):
        _stdout()
        _stdout(f"{name} ({len(members)}):")
        for tab in members:
            _stdout(f"  {tab_url(tab)[:80]}")

    _stdout()
    _stdout(
        f"Total: {len(tabs)} pinned tabs, {len(grouped)} folders, {len(unfiled)} unfiled"
    )

    return 0


def cmd_dump(args: argparse.Namespace) -> int:
    """Dump current workspace folders/tabs into declarative YAML."""
    _, session = load_session(args.profile)
    workspace_uuid = resolve_workspace(session, args.workspace)
    ws_name = workspace_name(session, workspace_uuid)

    folders = _ordered_folders(folders_for_workspace(session, workspace_uuid))

    # Build map-based structure: {workspace: {folder: {title: url}}}
    workspace_map: dict[str, object] = {}
    space = workspace_record_by_uuid(session, workspace_uuid)
    if isinstance(space, dict):
        workspace_meta: dict[str, object] = {}
        icon = space.get("icon")
        if isinstance(icon, str) and icon:
            workspace_meta["icon"] = icon
        container_tab_id = workspace_container_tab_id(session, workspace_uuid)
        if container_tab_id != 0:
            workspace_meta["containerTabId"] = container_tab_id
        if workspace_has_collapsed_pinned_tabs(space):
            workspace_meta["hasCollapsedPinnedTabs"] = True
        theme = workspace_theme_from_record(space)
        if not theme.is_default():
            workspace_meta["theme"] = theme.to_config_dict()
        if workspace_meta:
            workspace_map[WORKSPACE_META_KEY] = workspace_meta

    for folder in folders:
        folder_id = folder.get("id")
        tabs_map: dict[str, str] = {}
        if isinstance(folder_id, str):
            for tab in folder_tabs(session, folder_id, workspace_uuid):
                base_title = tab_title(tab) or tab_url(tab)[:60]
                url = tab_url(tab)
                if base_title and url:
                    title = base_title
                    suffix = 2
                    while title in tabs_map:
                        title = f"{base_title} ({suffix})"
                        suffix += 1
                    tabs_map[title] = url
        workspace_map[folder_display_name(folder)] = tabs_map

    result: dict = {ws_name: workspace_map}
    output = yaml.dump(
        result, default_flow_style=False, sort_keys=False, allow_unicode=True
    )

    if args.output:
        out_path = Path(args.output)
        try:
            out_path.write_text(output, encoding="utf-8")
        except OSError as exc:
            msg = f"Unable to write output file: {out_path}: {exc}"
            raise ZenFoldersError(msg) from exc
        _stdout(f"Written to {out_path}")
    else:
        _stdout_raw(output)

    return 0


def cmd_diff(args: argparse.Namespace) -> int:
    """Show a dry-run reconciliation plan for the provided config."""
    _, session = load_session(args.profile)
    raw_config = load_yaml(Path(args.config))
    workspace_spec, config_folders = parse_config(raw_config)

    preview_session = dict(session)
    preview_session["spaces"] = list(session.get("spaces", []))
    try:
        workspace_uuid = resolve_workspace(preview_session, workspace_spec.name)
        created_workspace = None
    except ZenFoldersError:
        workspace_uuid, created_workspace = ensure_workspace(
            preview_session, workspace_spec
        )

    plan = compute_plan(preview_session, config_folders, workspace_uuid)
    plan.workspace_to_create = created_workspace
    if created_workspace is None:
        plan_workspace_metadata_updates(
            plan,
            preview_session,
            workspace_uuid,
            workspace_spec,
        )

    if not plan.has_changes and not plan.warnings:
        _stdout("No changes needed. Session matches config.")
        return 0

    _print_plan_warnings(plan)
    if plan.workspace_to_create is not None:
        _stdout("Workspace to create:")
        _stdout(f"  + {plan.workspace_to_create.name}")
        _stdout()
    _print_workspace_updates(plan.workspace_updates)
    _print_plan_collection("Folders to create:", "+", plan.folders_to_create)
    _print_plan_collection("Folders to delete:", "-", plan.folders_to_delete)
    _print_tab_moves(plan.tab_moves)
    _print_tabs_to_create(plan.tabs_to_create)
    _print_tabs_to_ungroup(plan.tab_ungroups)
    _print_reorder_details(plan)

    return 0


def cmd_apply(args: argparse.Namespace) -> int:
    """Apply reconciliation plan to session file (with backup)."""
    runtime_state = require_zen_closed(args.profile)
    _print_runtime_warnings(runtime_state)
    path, session = load_session(args.profile)
    raw_config = load_yaml(Path(args.config))
    workspace_spec, config_folders = parse_config(raw_config)

    try:
        workspace_uuid = resolve_workspace(session, workspace_spec.name)
        created_workspace = None
    except ZenFoldersError:
        workspace_uuid, created_workspace = ensure_workspace(session, workspace_spec)

    plan = compute_plan(session, config_folders, workspace_uuid)
    plan.workspace_to_create = created_workspace
    if created_workspace is None:
        plan_workspace_metadata_updates(
            plan,
            session,
            workspace_uuid,
            workspace_spec,
        )

    if plan.warnings:
        for warning in plan.warnings:
            _stderr(f"Warning: {warning}")

    if not plan.has_changes:
        _stdout("No changes needed. Session matches config.")
        return 0

    _stdout(f"Plan: {', '.join(_plan_summary_parts(plan))}")

    if not args.yes:
        try:
            answer = input("Apply? [y/N] ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            _stdout("\nAborted.")
            return 1
        if answer not in ("y", "yes"):
            _stdout("Aborted.")
            return 1

    backup = backup_session(path)
    _stdout(f"Backup: {backup.name}")

    reconcile_workspace(session, config_folders, workspace_uuid, workspace_spec, plan)
    write_session(path, session)
    _stdout("Applied successfully.")
    return 0


def cmd_check(args: argparse.Namespace) -> int:
    """Run consistency checks for folder/group placeholder invariants."""
    _, session = load_session(args.profile)
    workspace_uuid = resolve_workspace(session, args.workspace)
    folders = folders_for_workspace(session, workspace_uuid)
    errors, warnings, folder_ids = _check_folder_structures(
        session, workspace_uuid, folders
    )
    errors.extend(_check_tab_group_refs(session, workspace_uuid, folder_ids))

    _print_check_warnings(warnings)

    if not errors:
        if warnings:
            _stdout()
        _stdout("Session check passed: no structural errors found.")
        return 0

    if warnings:
        _stdout()
    _stdout(f"Session check found {len(errors)} error(s):")
    _print_lines([f"  - {error}" for error in errors])
    return 1


def cmd_is_running(args: argparse.Namespace) -> int:
    """Return whether Zen appears to be actively using the target profile."""
    state = inspect_zen_runtime(args.profile)
    _print_runtime_warnings(state)
    if state.running:
        _stdout("running")
        return 0
    _stdout("not-running")
    return 1


def cmd_profile_path(args: argparse.Namespace) -> int:
    """Print the resolved profile directory path and exit."""
    _stdout(str(zen_profile_dir(args.profile)))
    return 0


# -- Main ---------------------------------------------------------------------


def main() -> int:
    """Parse CLI arguments and dispatch to the selected subcommand."""
    parser = argparse.ArgumentParser(
        description="Declarative pinned-tab folder management for Zen browser.",
        epilog=(
            "Zen must be closed for commands that modify the session.\n\n"
            "Optional workspace metadata example:\n"
            "  Work:\n"
            "    __workspace__:\n"
            '      icon: "🏢"\n'
            "      containerTabId: 6\n"
            "      hasCollapsedPinnedTabs: false\n"
            "      theme:\n"
            '        gradientColors: ["#8caaee", "#99d1db"]\n'
            "        opacity: 0.5\n"
            "        texture: 0\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "-p",
        "--profile",
        default=None,
        help=(
            "Zen profile directory name, a direct path to a profile directory/session file, "
            "or a human profile name from profiles.ini. Default: auto-detect from profiles.ini"
        ),
    )
    parser.add_argument(
        "-w",
        "--workspace",
        default="Work",
        help="Workspace name (resolved from session spaces array). Default: Work",
    )

    sub = parser.add_subparsers(dest="command", metavar="command")

    # -- list --
    ls = sub.add_parser("list", help="List all folders in order", aliases=["ls"])
    ls.add_argument("-v", "--verbose", action="store_true", help="Show tab URLs")

    # -- tabs --
    sub.add_parser("tabs", help="List all pinned tabs with folder assignments")

    # -- dump --
    dm = sub.add_parser("dump", help="Generate YAML config from current session state")
    dm.add_argument(
        "-o", "--output", metavar="FILE", help="Write to file instead of stdout"
    )

    # -- diff --
    df = sub.add_parser("diff", help="Show what changes would be made (dry run)")
    df.add_argument(
        "-c",
        "--config",
        default=str(DEFAULT_YAML),
        help=f"YAML config file (default: {DEFAULT_YAML})",
    )

    # -- apply --
    ap = sub.add_parser(
        "apply", help="Reconcile session with YAML config (requires Zen closed)"
    )
    ap.add_argument(
        "-c",
        "--config",
        default=str(DEFAULT_YAML),
        help=f"YAML config file (default: {DEFAULT_YAML})",
    )
    ap.add_argument("-y", "--yes", action="store_true", help="Skip confirmation prompt")

    # -- check --
    sub.add_parser("check", help="Run structural consistency check for folders")

    # -- is-running --
    sub.add_parser(
        "is-running",
        help="Exit 0 if Zen appears to be using the target profile, else 1",
    )

    # -- profile-path --
    sub.add_parser("profile-path", help="Print the resolved profile directory path")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        return 0

    dispatch = {
        "list": cmd_list,
        "ls": cmd_list,
        "tabs": cmd_tabs,
        "dump": cmd_dump,
        "diff": cmd_diff,
        "apply": cmd_apply,
        "check": cmd_check,
        "is-running": cmd_is_running,
        "profile-path": cmd_profile_path,
    }
    try:
        return dispatch[args.command](args)
    except ZenFoldersError as exc:
        _stderr(f"Error: {exc}")
        return 1
    except KeyboardInterrupt:
        _stderr("Interrupted.")
        return 130


if __name__ == "__main__":
    sys.exit(main())
