#!/usr/bin/env python3
# vi: set ft=python
"""Inspect and reconcile Zen session state and managed profile assets.

This file is the canonical Zen/Twilight tool entrypoint for the repo. It owns:

- the authored YAML schema exposed through ``home/george/zen/folders.yaml``
- the canonical internal config model used by the state compiler
- the managed subset of ``zen-sessions.jsonlz4``
- profile/runtime inspection helpers
- chrome and ``user.js`` asset diff/apply helpers
- the ``zentool`` CLI command tree

The implementation intentionally has three layers:

1. parse the authored workspace-map/node-tree YAML into authored node objects
2. normalize those authored nodes into canonical workspace/tab/folder specs
3. compile canonical specs into the managed Zen session subset while preserving
   opaque runtime fields on matched tabs, folders, groups, spaces, and
   top-level keys

Anything in the managed subset that is not declared by config is removed.
"""

from __future__ import annotations

import argparse
