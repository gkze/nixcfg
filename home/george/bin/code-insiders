#!/usr/bin/env bash
set -euo pipefail

candidates=(
  "/Applications/Visual Studio Code - Insiders.app/Contents/Resources/app/bin/code"
)

for candidate in "${candidates[@]}"; do
  if [[ -x "$candidate" ]]; then
    exec "$candidate" "$@"
  fi
done

printf 'code-insiders wrapper could not find the VS Code Insiders CLI inside the app bundle.\n' >&2
printf 'Checked:\n' >&2
for candidate in "${candidates[@]}"; do
  printf '  %s\n' "$candidate" >&2
done
printf 'Run your nix-darwin activation to install /Applications/Visual Studio Code - Insiders.app.\n' >&2
exit 1
