#!/usr/bin/env bash
set -euo pipefail

candidates=(
  "/Applications/Cursor.app/Contents/Resources/app/bin/cursor"
)

for candidate in "${candidates[@]}"; do
  if [[ -x "$candidate" ]]; then
    exec "$candidate" "$@"
  fi
done

printf 'cursor wrapper could not find the Cursor CLI inside the app bundle.\n' >&2
printf 'Checked:\n' >&2
for candidate in "${candidates[@]}"; do
  printf '  %s\n' "$candidate" >&2
done
printf 'Run your nix-darwin activation to install /Applications/Cursor.app.\n' >&2
exit 1
